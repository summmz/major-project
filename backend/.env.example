# MongoDB Atlas connection string (free tier: https://cloud.mongodb.com)
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/spotify-clone?retryWrites=true&w=majority

# Secret key for JWT token signing (use a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this

# Server port (default: 3001)
PORT=3001

# Google OAuth (get these from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5500
